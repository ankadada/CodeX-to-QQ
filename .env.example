# 独立 QQ Bot 凭证（不要复用你现有 openclaw 的 QQ bot）
QQBOT_APP_ID=
QQBOT_CLIENT_SECRET=

# 允许的用户 openid，逗号分隔；留空或 * 表示不限制
QQBOT_ALLOW_FROM=*

# 允许的群 openid，逗号分隔；留空或 * 表示不限制
QQBOT_ALLOW_GROUPS=

# true = 开启群 @ 消息；false = 只接单聊 C2C
QQBOT_ENABLE_GROUP=true

# Codex CLI 路径
CODEX_BIN=/opt/homebrew/bin/codex

# safe | dangerous
DEFAULT_MODE=dangerous

# 默认模型；留空表示使用 Codex 默认
DEFAULT_MODEL=

# 默认推理强度：low | medium | high；留空表示使用默认
DEFAULT_EFFORT=

# 工作区根目录
WORKSPACE_ROOT=./workspaces

# true = 把 reasoning 一起发回 QQ（更长）；false = 只发最终答案
SHOW_REASONING=false

# true = 把 QQ 附件下载到 workspace，并把图片作为图片输入交给 Codex
DOWNLOAD_ATTACHMENTS=true

# 每条消息最多处理多少个附件
MAX_ATTACHMENTS_PER_MESSAGE=6

# 最多把多少个图片附件作为 `codex -i` 输入
MAX_IMAGE_ATTACHMENTS=4

# 单个附件最大大小（字节），默认 25MB
MAX_ATTACHMENT_BYTES=26214400

# true = 自动提取常见文档/PDF/文本内容进 prompt
EXTRACT_ATTACHMENT_TEXT=true

# 单个文件最多提取多少字符
MAX_EXTRACTED_TEXT_CHARS_PER_FILE=4000

# 单条消息附件提取总字符上限
MAX_EXTRACTED_TEXT_TOTAL_CHARS=12000

# 全局同时运行的 Codex 任务数；0 = 不限制
MAX_GLOBAL_ACTIVE_RUNS=2

# token 达阈值时先自动压缩上下文再切新会话；false = 直接 reset
COMPACT_CONTEXT_ON_THRESHOLD=true

# 普通消息收到后先回一个“处理中”确认
SEND_ACK_ON_RECEIVE=true

# 单聊任务超过这个耗时后，最终回复优先走主动消息；0 = 关闭
PROACTIVE_FINAL_REPLY_AFTER_MS=30000

# 任务处理中自动发送进展更新的间隔；0 = 关闭
AUTO_PROGRESS_PING_MS=15000

# 单个任务最多自动发多少次进展更新；0 = 关闭
MAX_AUTO_PROGRESS_PINGS=2

# 私聊关键阶段主动推送进展；false = 关闭
PHASE_PROGRESS_NOTIFY=true

# 单个任务最多主动推送多少次关键阶段进展；0 = 关闭
MAX_PHASE_PROGRESS_NOTICES=3

# 两次关键阶段进展推送之间的最小间隔（毫秒）
MIN_PHASE_PROGRESS_NOTIFY_MS=5000

# 给短状态消息附带快捷操作按钮；false = 关闭
ENABLE_QUICK_ACTIONS=true

# 发送新进展卡片前，尝试撤回上一条旧进展卡片；默认建议关闭，避免 QQ 出现撤回提示
RETRACT_PROGRESS_MESSAGES=false

# 持久化保留多少条投递/运行审计记录
DELIVERY_AUDIT_MAX=120

# 每个会话最多排队多少条消息；0 = 不限制
MAX_QUEUE_PER_PEER=20

# 单次 Codex 任务超时（毫秒）；0 = 不限制
CODEX_TIMEOUT_MS=0

# 会话输入 token 达到阈值后自动 reset 再继续
MAX_INPUT_TOKENS_BEFORE_RESET=250000

# true | false
DEBUG_EVENTS=false
