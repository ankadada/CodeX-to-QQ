# Required QQ bot credentials
QQBOT_APP_ID=your_qq_bot_app_id
QQBOT_CLIENT_SECRET=your_qq_bot_client_secret

# Access control
# QQBOT_ALLOW_FROM=* allows all direct-message users. Leave empty to restrict explicitly.
QQBOT_ALLOW_FROM=
# Comma-separated allowed group openids. Leave empty to allow all groups when group mode is enabled.
QQBOT_ALLOW_GROUPS=
QQBOT_ENABLE_GROUP=true

# Provider: "codex" (default) or "claude"
PROVIDER=codex

# Provider binaries / defaults
CODEX_BIN=codex
# Claude Code binary (used when PROVIDER=claude)
CLAUDE_BIN=claude
DEFAULT_MODE=dangerous
DEFAULT_MODEL=
DEFAULT_EFFORT=medium
WORKSPACE_ROOT=./workspaces

# Debug / visibility
DEBUG_EVENTS=false
SHOW_REASONING=false

# Queue / execution
MAX_QUEUE_PER_PEER=20
MAX_GLOBAL_ACTIVE_RUNS=2
CODEX_TIMEOUT_MS=0
MAX_INPUT_TOKENS_BEFORE_RESET=250000
COMPACT_CONTEXT_ON_THRESHOLD=true

# Message UX
SEND_ACK_ON_RECEIVE=true
PROACTIVE_FINAL_REPLY_AFTER_MS=30000
AUTO_PROGRESS_PING_MS=15000
MAX_AUTO_PROGRESS_PINGS=2
PHASE_PROGRESS_NOTIFY=true
MAX_PHASE_PROGRESS_NOTICES=3
MIN_PHASE_PROGRESS_NOTIFY_MS=5000
ENABLE_QUICK_ACTIONS=true
QUICK_ACTION_RETRY_MS=21600000
TEXT_SHORTCUT_TTL_MS=600000
RETRACT_PROGRESS_MESSAGES=false
DELIVERY_AUDIT_MAX=120
QQ_API_TIMEOUT_MS=15000
QQ_DOWNLOAD_TIMEOUT_MS=30000

# Attachments
DOWNLOAD_ATTACHMENTS=true
MAX_ATTACHMENTS_PER_MESSAGE=6
MAX_IMAGE_ATTACHMENTS=4
MAX_ATTACHMENT_BYTES=26214400
EXTRACT_ATTACHMENT_TEXT=true
IMAGE_OCR_MODE=auto
MAX_IMAGE_OCR_CHARS_PER_FILE=1200
MAX_EXTRACTED_TEXT_CHARS_PER_FILE=4000
MAX_EXTRACTED_TEXT_TOTAL_CHARS=12000
PENDING_ACTION_TTL_MS=600000
